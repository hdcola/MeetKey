{
  "name": "@meetkey/center",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev-frontend": "vite",
    "build-frontend": "vite build",
    "build": "tauri build",
    "test": "pnpm run test:frontend:ci && pnpm run test:backend",
    "test:frontend": "vitest",
    "test:frontend:ci": "vitest run",
    "test:backend": "node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && cd src-tauri && cargo test --lib",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@meetkey/shared": "workspace:*",
    "pinia": "^3.0.4",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^14.12.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.0.5",
    "vue-tsc": "^3.2.5",
    "ws": "^8.19.0"
  }
}
