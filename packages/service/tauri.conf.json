{
  "productName": "MeetKey",
  "version": "0.1.0",
  "identifier": "com.meetkey.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vue",
    "beforeBuildCommand": "pnpm build:vue",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MeetKey",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "com.meetkey.app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
