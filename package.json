{
  "name": "meetkey",
  "version": "0.1.0",
  "description": "MeetKey - Stream Dock and Browser integration for Google Meet control",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:extension": "pnpm -C packages/browser-extension dev",
    "dev:center": "pnpm -C packages/center dev",
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "test:watch": "pnpm -r --if-present test:watch",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "test:center": "pnpm -C packages/center test",
    "test:center:watch": "pnpm -C packages/center test:frontend",
    "test:center:coverage": "pnpm -C packages/center test:coverage",
    "test:center:backend": "pnpm -C packages/center test:backend",
    "test:ui": "pnpm -C packages/center test:ui",
    "test:backend": "pnpm -C packages/center test:backend",
    "test:backend:coverage": "cd packages/center/src-tauri && cargo tarpaulin --lib --out Stdout",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:check": "eslint . --max-warnings 0",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist pnpm-lock.yaml && echo '✅ Clean complete: removed node_modules, dist directories, and pnpm-lock.yaml'"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
